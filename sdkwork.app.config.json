{
  "schemaVersion": 1,
  "kind": "sdkwork.app.config",
  "app": {
    "name": "sdkwork-dezhou",
    "displayName": "SDKWork Dezhou",
    "version": "0.1.0",
    "description": "SDKWork Texas Hold'em poker platform for tables, seats, and hand history",
    "owner": "sdkwork-dezhou",
    "domain": "game",
    "capability": "table"
  },
  "runtime": {
    "apiBaseUrl": "http://localhost:8096",
    "appApiPrefix": "/app/v3/api",
    "backendApiPrefix": "/backend/v3/api",
    "supportedDeploymentProfiles": ["standalone", "cloud"],
    "defaultDeploymentProfile": "standalone"
  },
  "sdk": {
    "appApiAuthority": "sdkwork-dezhou-app-api",
    "backendApiAuthority": "sdkwork-dezhou-backend-api",
    "appSdkFamily": "sdkwork-dezhou-app-sdk",
    "backendSdkFamily": "sdkwork-dezhou-backend-sdk"
  },
  "sdkDependencies": [],
  "dependencyApiExports": [],
  "dependencyApiSurfaces": [],
  "features": {
    "tables": true,
    "seats": true,
    "handHistory": true
  }
}
