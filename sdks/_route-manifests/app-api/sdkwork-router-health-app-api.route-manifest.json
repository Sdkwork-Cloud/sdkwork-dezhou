{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-router-health-app-api",
  "surface": "app-api",
  "owner": "sdkwork-dezhou",
  "domain": "game",
  "capability": "health",
  "apiAuthority": "sdkwork-dezhou-app-api",
  "sdkFamily": "sdkwork-dezhou-app-sdk",
  "prefix": "/",
  "source": {
    "crateRoot": "crates/sdkwork-router-health-app-api",
    "crateImport": "sdkwork_router_health_app_api",
    "openapiAuthority": "apis/app-api/game/dezhou-app-api.openapi.json"
  },
  "routes": [
    {
      "method": "GET",
      "path": "/app/v3/api/system/health",
      "operationId": "dezhou.health.check",
      "tags": ["health"],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": { "mode": "public" },
      "handler": { "module": "crate", "name": "dezhou_health_check" },
      "schemas": { "request": null, "response": "DezhouHealthResponse", "problem": "ProblemDetail" },
      "ownership": { "owner": "sdkwork-dezhou", "apiAuthority": "sdkwork-dezhou-app-api" },
      "source": { "file": "apis/app-api/game/dezhou-app-api.openapi.json" }
    },
    {
      "method": "GET",
      "path": "/app/v3/api/system/ready",
      "operationId": "dezhou.ready.check",
      "tags": ["health"],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": { "mode": "public" },
      "handler": { "module": "crate", "name": "dezhou_ready_check" },
      "schemas": { "request": null, "response": "DezhouHealthResponse", "problem": "ProblemDetail" },
      "ownership": { "owner": "sdkwork-dezhou", "apiAuthority": "sdkwork-dezhou-app-api" },
      "source": { "file": "apis/app-api/game/dezhou-app-api.openapi.json" }
    }
  ]
}
